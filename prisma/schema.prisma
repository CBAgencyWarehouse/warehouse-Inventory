generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String      @id @default(uuid())
  email       String      @unique
  name        String?
  password    String?
  companyName String?
  isActivated Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  otp         String?
  otpExpiry   DateTime?
  role        Role        @default(CLIENT)
  inventories Inventory[]
}

model Invitation {
  id        String   @id @default(uuid())
  email     String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Inventory {
  id          String   @id @default(uuid())
  name        String
  sku         String
  bin         String
  quantity    Int
  description String?
  condition   String
  images      String[] @default([])
  createdById String
  createdAt   DateTime @default(now())
  createdBy   User     @relation(fields: [createdById], references: [id])
}

enum Role {
  CLIENT
  CB
  ADMIN
}
